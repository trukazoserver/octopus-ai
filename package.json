{
	"name": "octopus-ai",
	"version": "0.1.0",
	"private": true,
	"description": "Self-hosted AI assistant with persistent memory, continuous learning, automations, and auto-improvable skills",
	"scripts": {
		"start": "octopus start",
		"launch": "octopus --web",
		"start:console": "octopus --console",
		"start:web": "pnpm --filter @octopus-ai/web dev",
		"start:desktop": "pnpm --filter @octopus-ai/desktop dev",
		"install:octopus": "node scripts/install.mjs",
		"build": "turbo build",
		"dev": "turbo dev",
		"lint": "turbo lint",
		"test": "turbo test",
		"typecheck": "turbo typecheck",
		"clean": "turbo clean"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"turbo": "^2.5.0",
		"typescript": "^5.8.3",
		"vitest": "^4.1.4"
	},
	"packageManager": "pnpm@10.8.0",
	"engines": {
		"node": ">=22.0.0"
	},
	"dependencies": {
		"@google/genai": "^2.0.1",
		"@google/generative-ai": "^0.24.1",
		"axios": "^1.15.2",
		"canvas": "^3.2.3",
		"jsonwebtoken": "^9.0.3",
		"sharp": "^0.34.5",
		"ws": "^8.20.0"
	},
	"main": "index.js",
	"directories": {
		"doc": "docs"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/trukazoserver/octopus-ai.git"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"bugs": {
		"url": "https://github.com/trukazoserver/octopus-ai/issues"
	},
	"homepage": "https://github.com/trukazoserver/octopus-ai#readme"
}
