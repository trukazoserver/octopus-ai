{
	"name": "octopus-ai",
	"version": "0.1.0",
	"private": true,
	"description": "Self-hosted AI assistant with human-like memory and auto-improvable skills",
	"scripts": {
		"start": "node packages/cli/dist/index.js start",
		"start:web": "pnpm --filter @octopus-ai/web dev",
		"start:desktop": "pnpm --filter @octopus-ai/desktop dev",
		"install:octopus": "node scripts/install.mjs",
		"build": "turbo build",
		"dev": "turbo dev",
		"lint": "turbo lint",
		"test": "turbo test",
		"typecheck": "turbo typecheck",
		"clean": "turbo clean"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"turbo": "^2.5.0",
		"typescript": "^5.8.3",
		"vitest": "^4.1.4"
	},
	"packageManager": "pnpm@10.8.0",
	"engines": {
		"node": ">=22.0.0"
	},
	"dependencies": {
		"@google/generative-ai": "^0.24.1",
		"better-sqlite3": "^12.9.0",
		"canvas": "^3.2.3",
		"ws": "^8.20.0"
	}
}
