{
	"name": "octopus-ai",
	"version": "0.1.0",
	"private": true,
	"description": "Self-hosted AI assistant with persistent memory, continuous learning, automations, and auto-improvable skills",
	"scripts": {
		"start": "node --disable-warning=ExperimentalWarning packages/cli/dist/index.js start --no-choice",
		"launch": "node --disable-warning=ExperimentalWarning packages/cli/dist/index.js --web",
		"start:console": "node --disable-warning=ExperimentalWarning packages/cli/dist/index.js --console",
		"start:web": "pnpm --filter @octopus-ai/web dev",
		"start:desktop": "pnpm --filter @octopus-ai/desktop dev",
		"install:octopus": "node scripts/install.mjs",
		"install:octopus:auto": "node scripts/install.mjs --yes",
		"install:octopus:skip-start": "node scripts/install.mjs --no-start",
		"docker:build": "docker compose -f docker/docker-compose.yml build",
		"docker:up": "docker compose -f docker/docker-compose.yml up -d --build",
		"docker:down": "docker compose -f docker/docker-compose.yml down",
		"build": "turbo build",
		"dev": "turbo dev",
		"lint": "turbo lint",
		"test": "turbo test",
		"infra:up": "docker compose --env-file docker/.env.integration -f docker/docker-compose.integration.yml up -d --wait",
		"infra:down": "docker compose --env-file docker/.env.integration -f docker/docker-compose.integration.yml down",
		"infra:ps": "docker compose --env-file docker/.env.integration -f docker/docker-compose.integration.yml ps",
		"test:live": "pnpm --filter @octopus-ai/core test:live",
		"test:live:postgres": "pnpm --filter @octopus-ai/core test:live:postgres",
		"test:live:vectors": "pnpm --filter @octopus-ai/core test:live:vectors",
		"test:live:local": "node scripts/run-live-tests.mjs",
		"test:live:local:postgres": "node scripts/run-live-tests.mjs postgres",
		"test:live:local:vectors": "node scripts/run-live-tests.mjs vectors",
		"typecheck": "turbo typecheck",
		"clean": "turbo clean"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"turbo": "^2.5.0",
		"typescript": "^5.8.3",
		"vitest": "^4.1.4"
	},
	"packageManager": "pnpm@10.8.0",
	"engines": {
		"node": ">=22.13.0"
	},
	"dependencies": {
		"@google/genai": "^2.0.1",
		"@google/generative-ai": "^0.24.1",
		"axios": "^1.15.2",
		"canvas": "^3.2.3",
		"jsonwebtoken": "^9.0.3",
		"sharp": "^0.34.5",
		"ws": "^8.20.0"
	},
	"main": "index.js",
	"directories": {
		"doc": "docs"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/trukazoserver/octopus-ai.git"
	},
	"keywords": [],
	"author": "",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/trukazoserver/octopus-ai/issues"
	},
	"homepage": "https://github.com/trukazoserver/octopus-ai#readme"
}
