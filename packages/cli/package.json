{
  "name": "@octopus-ai/cli",
  "version": "0.1.0",
  "description": "Octopus AI CLI - Ink-based TUI with memory and skill commands",
  "type": "module",
  "bin": {
    "octopus-ai": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "biome check src/",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@octopus-ai/core": "workspace:*",
    "ink": "^5.2.0",
    "react": "^18.3.1",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "ink-text-input": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "ink-markdown": "^1.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "^18.3.20",
    "rimraf": "^1.0.1",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
