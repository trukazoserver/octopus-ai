{
	"name": "@octopus-ai/core",
	"version": "0.1.0",
	"description": "Octopus AI Core SDK - Agent runtime, memory, continuous learning, skills, channels, and connection management",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./agent/*": {
			"types": "./dist/agent/*.d.ts",
			"default": "./dist/agent/*.js"
		},
		"./ai/*": {
			"types": "./dist/ai/*.d.ts",
			"default": "./dist/ai/*.js"
		},
		"./chat/*": {
			"types": "./dist/chat/*.d.ts",
			"default": "./dist/chat/*.js"
		},
		"./config/*": {
			"types": "./dist/config/*.d.ts",
			"default": "./dist/config/*.js"
		},
		"./connection/*": {
			"types": "./dist/connection/*.d.ts",
			"default": "./dist/connection/*.js"
		},
		"./memory/*": {
			"types": "./dist/memory/*.d.ts",
			"default": "./dist/memory/*.js"
		},
		"./mascots/*": {
			"types": "./dist/mascots/*.d.ts",
			"default": "./dist/mascots/*.js"
		},
		"./plugins/*": {
			"types": "./dist/plugins/*.d.ts",
			"default": "./dist/plugins/*.js"
		},
		"./plugins/mcp/*": {
			"types": "./dist/plugins/mcp/*.d.ts",
			"default": "./dist/plugins/mcp/*.js"
		},
		"./skills/*": {
			"types": "./dist/skills/*.d.ts",
			"default": "./dist/skills/*.js"
		},
		"./storage/*": {
			"types": "./dist/storage/*.d.ts",
			"default": "./dist/storage/*.js"
		},
		"./tasks/*": {
			"types": "./dist/tasks/*.d.ts",
			"default": "./dist/tasks/*.js"
		},
		"./tools/*": {
			"types": "./dist/tools/*.d.ts",
			"default": "./dist/tools/*.js"
		},
		"./voice/*": {
			"types": "./dist/voice/*.d.ts",
			"default": "./dist/voice/*.js"
		},
		"./utils/*": {
			"types": "./dist/utils/*.d.ts",
			"default": "./dist/utils/*.js"
		},
		"./transport/*": {
			"types": "./dist/transport/*.d.ts",
			"default": "./dist/transport/*.js"
		}
	},
	"scripts": {
		"build": "tsc && npm run copy:assets",
		"dev": "tsc --watch",
		"lint": "biome lint src/",
		"test": "vitest run",
		"test:live": "vitest run src/__tests__/storage-postgres-live.test.ts src/__tests__/vector-store-live.test.ts src/__tests__/zhipu-live.test.ts src/__tests__/reasoning-live.test.ts",
		"test:live:postgres": "vitest run src/__tests__/storage-postgres-live.test.ts",
		"test:live:vectors": "vitest run src/__tests__/vector-store-live.test.ts",
		"typecheck": "tsc --noEmit",
		"clean": "rimraf dist",
		"copy:assets": "node scripts/copy-assets.cjs",
		"build:wasm": "bash scripts/build-sqljs-fts5.sh",
		"build:full": "npm run build:wasm && npm run build",
		"prebuild": "node -e \"const p=require('path');const f=p.join(__dirname,'src','assets','sql-wasm-fts5.wasm');const fs=require('fs');if(!fs.existsSync(f)){console.warn('⚠️  Custom FTS5 WASM not found. Run: npm run build:wasm');console.warn('   Falling back to default sql.js WASM (FTS5 will be unavailable).')}\""
	},
	"dependencies": {
		"@fastify/cors": "^11.2.0",
		"@napi-rs/canvas": "^1.0.0",
		"@sinclair/typebox": "^0.34.33",
		"@slack/bolt": "^4.7.0",
		"@types/multer": "^2.1.0",
		"@types/node-cron": "^3.0.11",
		"@whiskeysockets/baileys": "7.0.0-rc.9",
		"adm-zip": "^0.5.17",
		"discord.js": "^14.26.3",
		"eventemitter3": "^5.0.1",
		"fastify": "^5.8.5",
		"form-data": "^4.0.5",
		"grammy": "^1.42.0",
		"js-tiktoken": "^1.0.21",
		"multer": "^2.1.1",
		"nanoid": "^5.1.5",
		"node-cron": "^4.2.1",
		"officeparser": "^7.2.2",
		"patchright": "^1.61.0",
		"pdfjs-dist": "^6.0.0",
		"pg": "^8.16.3",
		"pino": "^9.6.0",
		"playwright": "^1.59.1",
		"playwright-extra": "^4.3.6",
		"puppeteer-core": "^24.40.0",
		"puppeteer-extra": "^3.3.6",
		"puppeteer-extra-plugin-recaptcha": "^3.6.8",
		"puppeteer-extra-plugin-stealth": "^2.11.2",
		"sharp": "^0.34.5",
		"sql.js": "1.12.0",
		"tesseract.js": "^7.0.0",
		"ws": "^8.18.0",
		"xlsx": "^0.18.5"
	},
	"devDependencies": {
		"@types/adm-zip": "^0.5.8",
		"@types/node": "^22.14.0",
		"@types/pg": "^8.15.5",
		"@types/ws": "^8.18.0",
		"rimraf": "^6.0.1",
		"typescript": "^5.8.3",
		"vitest": "^3.1.1"
	}
}
